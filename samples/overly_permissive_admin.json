{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "BadAdminAllowAll",
      "Effect": "Allow",
      "Action": "*",
      "Resource": "*"
    },
    {
      "Sid": "BadS3Wildcard",
      "Effect": "Allow",
      "Action": "s3:*",
      "Resource": "*"
    },
    {
      "Sid": "BadKmsDecryptOnAny",
      "Effect": "Allow",
      "Action": "kms:Decrypt",
      "Resource": "*"
    },
    {
      "Sid": "BadPassRoleUnrestricted",
      "Effect": "Allow",
      "Action": ["iam:PassRole", "iam:AttachRolePolicy"],
      "Resource": "*"
    },
    {
      "Sid": "BadExfilNoCondition",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "secretsmanager:GetSecretValue"],
      "Resource": "arn:aws:s3:::customer-data/*"
    }
  ]
}
