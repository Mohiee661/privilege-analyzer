{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadSpecificBucket",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:ListBucket"],
      "Resource": [
        "arn:aws:s3:::prod-reports",
        "arn:aws:s3:::prod-reports/*"
      ],
      "Condition": {
        "StringEquals": { "aws:SourceVpce": "vpce-0abcd1234" },
        "Bool": { "aws:MultiFactorAuthPresent": "true" }
      }
    }
  ]
}
